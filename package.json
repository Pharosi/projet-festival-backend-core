{
  "name": "festival-backend-core",
  "version": "0.1.0",
  "private": true,
  "description": "API backend pour la gestion d'un festival de photographie.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main/server.ts",
    "build": "tsc",
    "start": "node dist/main/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:up": "docker compose up -d database",
    "db:down": "docker compose down"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
